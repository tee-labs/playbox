{
  // Default provider configuration for the AI API Gateway
  // Edit this file to add/remove providers and models
  // No restart needed for local dev — changes picked up on next request
  "providers": {
    // Ollama — local/self-hosted models via Ollama
    "ollama": {
      "type": "openai",
      "family": "openai",
      "endpoint": "https://ollama.com",
      "key": "Ollama",
      "models": ["gemma4:31b", "glm-4.7", "minimax-m2.5", "qwen3-vl:235b", "qwen3-coder:480b", "qwen3-vl:235b-instruct"]
    },
    // LongCat — primary OpenAI-compatible provider
    "longcat": {
      "type": "openai",
      "family": "openai",
      "endpoint": "https://api.longcat.chat/openai",
      "key": "LongCat",
      "models": [
        "LongCat-Flash-Chat",
        "LongCat-Flash-Lite",
        "LongCat-Flash-Thinking",
        "LongCat-Pro-Preview",
        "LongCat-Flash-Chat-2602-Exp",
        "LongCat-2.0-Preview",
        "Sphynx"
      ]
    },
    // LongCat (Anthropic protocol)
    "longcat_claude": {
      "type": "anthropic",
      "family": "anthropic",
      "endpoint": "https://api.longcat.chat/anthropic",
      "key": "LongCat",
      "models": [
        "LongCat-Flash-Chat",
        "LongCat-Flash-Lite",
        "LongCat-Flash-Thinking",
        "LongCat-Pro-Preview",
        "LongCat-Flash-Chat-2602-Exp",
        "LongCat-2.0-Preview",
        "Sphynx"
      ],
      "authType": "bearer"
    },
    // Cerebras — high-speed inference
    // "cerebras": {
    //   "type": "openai",
    //   "family": "openai",
    //   "endpoint": "https://api.cerebras.ai",
    //   "key": "Cerebras",
    //   "models": ["qwen-3-235b-a22b-instruct-2507"]
    // },
    // Google Gemini (native API)
    // "gemini": {
    //   "type": "google",
    //   "family": "gemini",
    //   "endpoint": "https://generativelanguage.googleapis.com",
    //   "key": "Gemini",
    //   "models": ["gemini-flash-latest", "gemini-3-flash-preview", "gemini-3.1-flash-lite-preview", "gemini-2.5-flash", "gemini-flash-lite-latest", "gemini-2.5-flash-lite", "gemma-4-31b-it"]
    // },
    // Gemini CLI — OAuth-based access
    // "gemini-cli": {
    //   "type": "gemini-cli",
    //   "family": "gemini",
    //   "endpoint": "https://cloudcode-pa.googleapis.com/v1internal",
    //   "key": "Gemini",
    //   "models": ["gemini-3-flash-preview", "gemini-3.1-flash-lite-preview", "gemini-2.5-flash", "gemini-2.5-flash-lite"]
    // },
    // ModelScope — Chinese model hub
    "modelscope": {
      "type": "openai",
      "family": "openai",
      "endpoint": "https://api-inference.modelscope.cn",
      "key": "ModelScope",
      "models": [
        "deepseek-ai/DeepSeek-V3.2",
        "deepseek-ai/DeepSeek-V4-Flash",
        "MiniMax/MiniMax-M2.5",
        "moonshotai/Kimi-K2.5",
        "Qwen/Qwen3.5-397B-A17B",
        "Qwen/Qwen3.5-35B-A3B",
        "Qwen/Qwen3.5-27B",
        "Qwen/Qwen3.5-122B-A10B",
        "ZhipuAI/GLM-5",
        "ZhipuAI/GLM-5.1",
        "ZhipuAI/GLM-4.7-Flash"
      ]
    },
    // NVIDIA NIM
    "nvidia": {
      "type": "openai",
      "family": "openai",
      "endpoint": "https://integrate.api.nvidia.com",
      "key": "Nvidia",
      "models": [
        "z-ai/glm-5.1",
        "qwen/qwen3-coder-480b-a35b-instruct",
        "qwen/qwen3.5-397b-a17b",
        "qwen/qwen3.5-122b-a10b",
        "google/gemma-4-31b-it",
        "minimaxai/minimax-m2.5",
        "minimaxai/minimax-m2.7",
        "nvidia/nemotron-3-super-120b-a12b",
        "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning",
        "deepseek-ai/deepseek-v4-flash",
        "deepseek-ai/deepseek-v4-pro"
      ]
    },
    // Doubao (ByteDance)
    "doubao": {
      "type": "openai",
      "family": "openai",
      "endpoint": "https://ark.cn-beijing.volces.com/api/coding/v3",
      "key": "Doubao",
      "models": ["ark-code-latest"]
    },
    // Gitee AI — embedding models
    "gitee-ai": {
      "type": "openai",
      "family": "embedding",
      "endpoint": "https://ai.gitee.com",
      "key": "GiteeAI",
      "models": ["bge-m3", "Qwen3-Embedding-8B"]
    }
    // Cloudflare AI Workers
    // "cloudflare": {
    //   "type": "worker",
    //   "family": "openai",
    //   "endpoint": "https://api.cloudflare.com",
    //   "key": "Cloudflare",
    //   "models": ["@cf/moonshotai/kimi-k2.6"]
    // }
  },
  // Default provider when model is not found
  "default_provider": "longcat"
}
