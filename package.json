{
  "name": "playbox",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx wrangler types && next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:vercel": "vercel --prod",
    "test": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "smoke-test": "SMOKE_SKIP_ANTHROPIC=1 node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@cloudflare/vitest-pool-workers": "^0.12.0",
    "@cloudflare/workers-types": "^4.20260425.1",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.79.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@opennextjs/cloudflare": "^1.1.0",
    "@types/qrcode-generator": "^0.0.16",
    "@vercel/blob": "^2.3.3",
    "@vercel/kv": "^3.0.0",
    "@vercel/postgres": "^0.10.0",
    "antd": "^6.3.5",
    "dayjs": "^1.11.20",
    "langextract": "^1.2.0",
    "next": "15.5.15",
    "nodemailer": "^8.0.5",
    "qrcode-generator": "^2.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "vconsole": "^3.15.1"
  }
}
